server {
    listen 80;
    listen [::]:80;
    server_name flask.opencodingsociety.com fopl-flask.opencodingsociety.com;

    # Proxy volunteer API to Node/SQLite service on 8322
    location /volunteer-api/ {
        proxy_pass http://localhost:8322/;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;

        add_header "Access-Control-Allow-Origin" "*" always;
        add_header "Access-Control-Allow-Methods" "GET, POST, PATCH, DELETE, OPTIONS" always;
        add_header "Access-Control-Allow-Headers" "Content-Type" always;

        if ($request_method = OPTIONS) {
            return 204;
        }
    }

    # Proxy Socket.IO connections to 8500
    location /socket.io/ {
        proxy_pass http://localhost:8500;
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection "upgrade";
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
    }

    # Proxy all other traffic to Flask app on 8321
    # CORS (including OPTIONS preflight) is handled entirely by Flask-CORS.
    # Do NOT add Access-Control-Allow-Origin here — nginx add_header inside if
    # blocks has known inheritance issues and causes duplicate headers.
    location / {
        proxy_pass http://localhost:8321;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        client_max_body_size 10m;
    }
}
